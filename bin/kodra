#!/usr/bin/env bash
#
# Kodra WSL CLI
# Main command interface
#

KODRA_DIR="${KODRA_DIR:-$HOME/.kodra}"
KODRA_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kodra"

# Colors
C_RESET='\033[0m'
C_RED='\033[0;31m'
C_GREEN='\033[0;32m'
C_YELLOW='\033[0;33m'
C_BLUE='\033[0;34m'
C_CYAN='\033[0;36m'
C_WHITE='\033[1;37m'
C_GRAY='\033[0;90m'

show_help() {
    # Gradient colors: purple вҶ’ cyan
    local C_LOGO_1='\033[38;5;135m'   # Purple
    local C_LOGO_2='\033[38;5;141m'   # Light purple
    local C_LOGO_3='\033[38;5;147m'   # Lavender
    local C_LOGO_4='\033[38;5;117m'   # Light blue
    local C_LOGO_5='\033[38;5;87m'    # Cyan
    local C_DIM='\033[2m'
    local C_BOLD='\033[1m'

    local ver
    ver="$(show_version)"
    local theme="default"
    if [ -f "$KODRA_CONFIG_DIR/theme" ]; then
        theme="$(cat "$KODRA_CONFIG_DIR/theme")"
    fi

    # Plain-text fallback for NO_COLOR or non-TTY
    if [ -n "${NO_COLOR:-}" ] || [ ! -t 1 ]; then
        echo ""
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ"
        echo "  в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
        echo "  в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—"
        echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘"
        echo "  в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘"
        echo "  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘"
        echo "  в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ"
        echo ""
        echo "  v${ver} вҖў WSL Edition вҖў by Code To Cloud"
        echo "  kodra.wsl.codetocloud.io"
        echo "  Theme: ${theme}"
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ"
        echo ""
        echo "  System Health"
        echo "    kodra doctor        Check system health and tool status"
        echo "    kodra doctor --fix  Auto-reinstall missing tools"
        echo ""
        echo "  Maintenance"
        echo "    kodra update        Update all 25+ installed tools"
        echo "    kodra repair        Interactive repair menu"
        echo "    kodra repair --all  Repair everything automatically"
        echo ""
        echo "  Setup"
        echo "    kodra setup         Re-run first-time configuration"
        echo "    kodra fetch         Show system info (fastfetch)"
        echo ""
        echo "  Info"
        echo "    kodra version       Show version"
        echo "    kodra help          Show this help"
        echo ""
        echo "  Tips:"
        echo "    Run kodra doctor after install to verify everything"
        echo "    Run kodra update to keep all tools current"
        echo "    Run kodra repair --all to fix any issues"
        echo ""
        return
    fi

    echo ""
    echo -e "${C_DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${C_RESET}"
    echo -e "${C_LOGO_1}  в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${C_RESET}"
    echo -e "${C_LOGO_2}  в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—${C_RESET}"
    echo -e "${C_LOGO_3}  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘${C_RESET}"
    echo -e "${C_LOGO_4}  в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘${C_RESET}"
    echo -e "${C_LOGO_5}  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘${C_RESET}"
    echo -e "${C_LOGO_5}  в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ${C_RESET}"
    echo ""
    echo -e "  ${C_BOLD}v${ver}${C_RESET} ${C_DIM}вҖў${C_RESET} WSL Edition ${C_DIM}вҖў${C_RESET} by Code To Cloud"
    echo -e "  ${C_DIM}kodra.wsl.codetocloud.io${C_RESET}"
    echo -e "  ${C_DIM}Theme: ${theme}${C_RESET}"
    echo -e "${C_DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${C_RESET}"
    echo ""
    echo -e "  ${C_BOLD}System Health${C_RESET}"
    echo -e "    ${C_LOGO_5}kodra doctor${C_RESET}        Check system health and tool status"
    echo -e "    ${C_LOGO_5}kodra doctor --fix${C_RESET}  Auto-reinstall missing tools"
    echo ""
    echo -e "  ${C_BOLD}Maintenance${C_RESET}"
    echo -e "    ${C_LOGO_5}kodra update${C_RESET}        Update all 25+ installed tools"
    echo -e "    ${C_LOGO_5}kodra repair${C_RESET}        Interactive repair menu"
    echo -e "    ${C_LOGO_5}kodra repair --all${C_RESET}  Repair everything automatically"
    echo ""
    echo -e "  ${C_BOLD}Setup${C_RESET}"
    echo -e "    ${C_LOGO_5}kodra setup${C_RESET}         Re-run first-time configuration"
    echo -e "    ${C_LOGO_5}kodra fetch${C_RESET}         Show system info (fastfetch)"
    echo ""
    echo -e "  ${C_BOLD}Info${C_RESET}"
    echo -e "    ${C_LOGO_5}kodra version${C_RESET}       Show version"
    echo -e "    ${C_LOGO_5}kodra help${C_RESET}          Show this help"
    echo ""
    echo -e "  ${C_DIM}Tips:${C_RESET}"
    echo -e "    ${C_DIM}Run kodra doctor after install to verify everything${C_RESET}"
    echo -e "    ${C_DIM}Run kodra update to keep all tools current${C_RESET}"
    echo -e "    ${C_DIM}Run kodra repair --all to fix any issues${C_RESET}"
    echo ""
}

show_version() {
    if [ -f "$KODRA_DIR/VERSION" ]; then
        cat "$KODRA_DIR/VERSION"
    else
        echo "0.3.0"
    fi
}

run_doctor() {
    "$KODRA_DIR/bin/kodra-sub/doctor.sh" "$@"
}

run_repair() {
    "$KODRA_DIR/bin/kodra-sub/repair.sh" "$@"
}

run_update() {
    "$KODRA_DIR/bin/kodra-sub/update.sh"
}

run_setup() {
    "$KODRA_DIR/bin/kodra-sub/first-run.sh"
}

run_fetch() {
    if command -v fastfetch &> /dev/null; then
        fastfetch
    elif command -v neofetch &> /dev/null; then
        neofetch
    else
        echo -e "${C_CYAN}System Information${C_RESET}"
        echo ""
        echo -e "  OS: $(lsb_release -d 2>/dev/null | cut -f2 || cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)"
        echo -e "  Kernel: $(uname -r)"
        echo -e "  Shell: $SHELL"
        echo -e "  User: $USER"
        if grep -qEi "(microsoft|wsl)" /proc/version 2>/dev/null; then
            echo -e "  WSL: Yes"
        fi
        echo ""
    fi
}

# Main command router
case "${1:-help}" in
    doctor)
        shift
        run_doctor "$@"
        ;;
    repair|fix)
        shift
        run_repair "$@"
        ;;
    update)
        run_update
        ;;
    setup)
        run_setup
        ;;
    fetch|info)
        run_fetch
        ;;
    version|--version|-v)
        show_version
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo -e "${C_RED}Unknown command:${C_RESET} $1"
        show_help
        exit 1
        ;;
esac
